pipeline {
    agent any
    environment {
        // Charger les credentials pour S3 et MLflow
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        BACKEND_STORE_URI = 'sqlite:///mlflow.db'
        ARTIFACT_STORE_URI = 's3://bucketkadiri/Folder0/'
        MLFLOW_TRACKING_URI = 'http://mlflow-server:4000' // Nom du conteneur utilisé pour le serveur MLflow
    }
    stages {
        stage('Checkout') {
            steps {
                // Cloner le code source depuis GitHub
                checkout scm
            }
        }

        stage('Setup Docker Network') {
            steps {
                // Créer un réseau Docker pour que les conteneurs puissent communiquer
                sh 'docker network create mlflow-network || true'
            }
        }

        stage('Build Docker Image for MLflow') {
            steps {
                dir('CICD/mlflow') {
                    // Construire l'image Docker pour MLflow
                    sh 'docker build -t mlflow-image .'
                }
            }
        }
        stage('Generate .env File') {
            steps {
                dir('CICD') {
                    script {
                        // Générer un fichier .env avec les variables d'environnement
                        writeFile file: '.env', text: """
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
BACKEND_STORE_URI=${BACKEND_STORE_URI}
ARTIFACT_STORE_URI=${ARTIFACT_STORE_URI}
MLFLOW_TRACKING_URI=${MLFLOW_TRACKING_URI}
"""
                    }
                    // Vérification du fichier .env (à supprimer en production)
                    sh 'cat .env'
                }
            }
        }
        
        stage('Prepare Volume') {
            steps {
                // Créer le répertoire tmp pour le montage
                sh 'mkdir -p tmp'
            }
        }
        
        stage('Start MLflow Server') {
            steps {
                script {
                    // Démarrer le serveur MLflow avec le montage du volume
                    sh """
                    docker run -d --name mlflow-server \
                        --network mlflow-network \
                        --env-file .env \
                        -v "\$(pwd)/tmp:/home/app/tmp" \
                        -p 4000:4000 \
                        mlflow-image
                    """
                }
            }
        }
        }


        stage('Run Training Script') {
            steps {
                dir('CICD/mlflow') {
                    // Exécuter le script train.py dans un autre conteneur connecté au réseau Docker
                    sh """
                    docker run --rm --network mlflow-network \
                        --env-file ../.env \
                        -v "\$(pwd):/home/app" \
                        mlflow-image python /home/app/train.py
                    """
                }
            }
        }
    }
    post {
        always {
            // Nettoyer les conteneurs et le réseau Docker après l'exécution
            echo 'Nettoyage des conteneurs et du réseau Docker...'
            sh """
            docker rm -f mlflow-server || true
            docker network rm mlflow-network || true
            """
        }
        success {
            echo 'Pipeline exécutée avec succès !'
        }
        failure {
            echo 'La pipeline a échoué.'
        }
    }
}
