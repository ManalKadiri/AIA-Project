pipeline {
    agent any
    environment {
        APP_URI = credentials('app-uri')
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        BACKEND_STORE_URI = credentials('backend-store-uri')
        ARTIFACT_STORE_URI = credentials('artifact-store-uri')
        POSTMARK_API_KEY = credentials('postmark-api-key')
        MLFLOW_EXPERIMENT_NAME = credentials('mlflow-experiment-name')
    }
    stages {
        stage('Checkout') {
            steps {
                // Cloner le dépôt GitHub
                checkout scm
            }
        }

        stage('Build Docker Images') {
            steps {
                parallel (
                    "Build MLflow Image": {
                        dir('CICD/mlflow') { // Pas besoin d'ajouter "main"
                            sh 'docker build -t mlflow-image .'
                        }
                    },
                    "Build API Image": {
                        dir('CICD/API') { // Pas besoin d'ajouter "main"
                            sh 'docker build -t fraud-detection-api .'
                        }
                    }
                )
            }
        }

        stage('Generate .env File') {
            steps {
                dir('CICD') { // Pas besoin d'ajouter "main"
                    script {
                        writeFile file: '.env', text: """
APP_URI=${APP_URI}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
BACKEND_STORE_URI=${BACKEND_STORE_URI}
ARTIFACT_STORE_URI=${ARTIFACT_STORE_URI}
POSTMARK_API_KEY=${POSTMARK_API_KEY}
MLFLOW_EXPERIMENT_NAME=${MLFLOW_EXPERIMENT_NAME}
"""
                    }
                    sh 'cat .env'
                }
            }
        }

        stage('Run Training Script') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        // Monter et vérifier les fichiers dans le conteneur
                        sh """
                        docker run --env-file ../.env -p 4000:4000 \
                        -v "\$(pwd):/home/app" mlflow-image \
                        ls -al /home/app
                        """
                    }
                    // Lancer le script de formation
                    sh """
                    docker run --env-file ../.env -p 4000:4000 \
                        -v "\$(pwd):/home/app" mlflow-image \
                        python /home/app/train.py
                    """
                }
            }
        }


        stage('Run Tests') {
            steps {
                dir('CICD/tests') { // Les tests sont dans un sous-dossier spécifique
                    script {
                        def test_result = sh(script: """
                        docker run --env-file ../.env \
                            -v "\$(pwd):/home/app/tests" mlflow-image \
                            pytest --maxfail=1 --disable-warnings -q /home/app/tests
                        """, returnStatus: true)

                        if (test_result != 0) {
                            echo "Tests failed. Sending alert email..."
                            dir('CICD/mlflow') {
                                sh """
                                python send_email.py \
                                    "Tests échoués" \
                                    "Un ou plusieurs tests ont échoué. Veuillez vérifier les logs Jenkins."
                                """
                            }
                            error "Tests failed. Pipeline stopped."
                        } else {
                            echo "All tests passed successfully."
                        }
                    }
                }
            }
        }

        stage('Deploy API') {
            steps {
                dir('CICD/API') { // Pas besoin d'ajouter "main"
                    sh """
                    docker run --network host -d \
                        -v "\$(pwd):/home/app" \
                        fraud-detection-api \
                        python /home/app/api.py
                    """
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline terminé. Vérifiez l'état des étapes précédentes."
        }
        failure {
            echo "Une erreur est survenue. Envoi d'un email d'alerte..."
            dir('CICD/mlflow') {
                sh """
                python send_email.py \
                    "Pipeline Jenkins Échoué" \
                    "Le pipeline Jenkins a échoué dans une des étapes. Veuillez vérifier les logs pour plus de détails."
                """
            }
        }
    }
}
