pipeline {
    agent {
        docker {
            image 'continuumio/miniconda3'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }
    environment {
        APP_URI = credentials('app-uri')
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        BACKEND_STORE_URI = credentials('backend-store-uri')
        ARTIFACT_STORE_URI = credentials('artifact-store-uri')
        POSTMARK_API_KEY = credentials('postmark-api-key')
        MLFLOW_EXPERIMENT_NAME = credentials('mlflow-experiment-name')
    }
    triggers {
        pollSCM('H/5 * * * *') // Vérifie toutes les 5 minutes les changements sur GitHub
    }
    stages {
        stage('Cloner le dépôt GitHub') {
            steps {
                git branch: 'main', url: 'https://github.com/USERNAME/AIA-project.git'
            }
        }
        stage('Entraîner le modèle') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        sh 'python train.py'
                    }
                }
            }
        }
        stage('Exécuter les tests') {
            steps {
                dir('CICD/tests') {
                    script {
                        // Exécute les tests unitaires
                        sh 'pytest test_data_preprocessing.py'
                        sh 'pytest test_model_training.py'
                    }
                }
            }
        }
        stage('Vérifier les performances du modèle') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        sh 'python check_model_performance.py'
                    }
                }
            }
        }
        stage('Déployer via API') {
            steps {
                dir('CICD/API') {
                    script {
                        sh 'docker build -t fraud-detection-api .'
                        sh 'docker run -d -p 8000:8000 fraud-detection-api'
                    }
                }
            }
        }
    }
    post {
        success {
            echo 'Pipeline exécuté avec succès ! 🎉'
        }
        failure {
            echo 'Échec de l’exécution du pipeline. Vérifiez les logs pour plus de détails.'
        }
    }
}
