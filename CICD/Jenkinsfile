pipeline {
    agent any
    environment {
        // Injecter les credentials Jenkins
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        BACKEND_STORE_URI = credentials('backend-store-uri')
        ARTIFACT_STORE_URI = credentials('artifact-store-uri')
        APP_URI = credentials('app-uri')
        POSTMARK_API_KEY = credentials('postmark-api-key') // Clé API Postmark
        MLFLOW_TRACKING_URI = credentials('mlflow-tracking-uri') // Lien de suivi MLflow
    }
    stages {
        stage('Checkout') {
            steps {
                // Cloner le code source depuis GitHub
                checkout scm
            }
        }
        stage('Build Docker Images') {
            steps {
                parallel (
                    "Build MLflow Image": {
                        dir('CICD/mlflow') {
                            sh 'docker build -t mlflow-image .'
                        }
                    },
                    "Build API Image": {
                        dir('CICD/API') {
                            sh 'docker build -t fraud-detection-api .'
                        }
                    }
                )
            }
        }

        stage('Install Python Dependencies') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        sh """
                        echo "Installing Python dependencies..."
                        pip install requests pytest --break-system-packages
                        """
                    }
                }
            }
        }

        stage('Generate .env File') {
            steps {
                dir('CICD') { // Naviguer dans le bon répertoire
                    script {
                        writeFile file: '.env', text: """
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
BACKEND_STORE_URI=${BACKEND_STORE_URI}
ARTIFACT_STORE_URI=${ARTIFACT_STORE_URI}
APP_URI=${APP_URI}
MLFLOW_TRACKING_URI=${MLFLOW_TRACKING_URI}
"""
                    }
                    // Vérifiez si le fichier .env est bien généré
                    sh 'echo "Vérification du fichier .env :" && ls -la && cat .env'
                }
            }
        }

        stage('Run Training Script') {
            steps {
                dir('CICD/mlflow') {
                    sh """
                    docker run --env-file ../.env -p 4000:4000 -v "\$(pwd):/home/app" mlflow-image python /home/app/train.py
                    """
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        // Lancer les tests dans le conteneur Docker
                        sh """
                        docker run --env-file ../.env \
                            -v "\$(pwd)/tests:/home/app/tests" \
                            -v "\$(pwd)/mlflow:/home/app/mlflow" \
                            mlflow-image pytest /home/app/tests --disable-warnings
                        """
                    }
                }
            }
        }

        stage('Run Model Validation') {
            steps {
                dir('CICD/mlflow') {
                    echo "Running model validation script..."
                    sh """
                    docker run --env-file ../.env \
                        -v "\$(pwd):/home/app" mlflow-image \
                        python /home/app/validate_model.py
                    """
                }
            }
        }

        stage('Deploy API') {
            steps {
                dir('CICD/API') {
                    script {
                        echo "Deploying Fraud Detection API..."
                        sh """
                        docker stop fraud-api || true
                        docker rm fraud-api || true
                        docker run -d --name fraud-api \
                            --env-file ../.env \
                            -p 8000:8000 fraud-detection-api
                        """
                    }
                }
            }
        }

        stage('Post-build Cleanup') {
            steps {
                echo "Cleaning up Docker images..."
                sh 'docker rmi mlflow-image fraud-detection-api || true'
            }
        }
    }
    
    post {
        always {
            echo "Pipeline terminé. Vérifiez l'état des tests et des étapes précédentes."
        }
        failure {
            echo "Une erreur est survenue. Envoi d'un email d'alerte..."
            dir('CICD/mlflow') {
                sh """
                python3 send_email.py \
                    "Pipeline Jenkins Échoué" \
                    "Le pipeline Jenkins a échoué dans une des étapes. Veuillez vérifier les logs pour plus de détails."
                """
            }
        }
    }
}
