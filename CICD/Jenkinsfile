pipeline {
    agent any
    environment {
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        BACKEND_STORE_URI = 'sqlite:///mlflow.db'
        ARTIFACT_STORE_URI = 's3://bucketkadiri/Folder0/'
        MLFLOW_TRACKING_URI = 'http://mlflow-server:4000'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/ManalKadiri/AIA-Project.git',
                        credentialsId: 'your-credentials-id' // Remplacez par l'ID des credentials Jenkins
                    ]]
                ])
            }
        }

        stage('Setup Docker Network') {
            steps {
                script {
                    sh """
                    docker ps -q --filter network=mlflow-network | xargs -r docker network disconnect -f mlflow-network || true
                    docker network rm mlflow-network || true
                    docker network create mlflow-network
                    """
                }
            }
        }

        stage('Generate .env File') {
            when {
                expression { currentBuild.result == null }
            }
            steps {
                dir('CICD') {
                    script {
                        writeFile file: '.env', text: """
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
BACKEND_STORE_URI=${BACKEND_STORE_URI}
ARTIFACT_STORE_URI=${ARTIFACT_STORE_URI}
MLFLOW_TRACKING_URI=${MLFLOW_TRACKING_URI}
"""
                        // Diagnostics pour confirmer la création correcte du fichier .env
                        sh 'ls -la .env && cat .env'
                        sh 'chmod 644 .env'
                    }
                }
            }
        }

        stage('Build Docker Image for MLflow') {
            when {
                expression { currentBuild.result == null }
            }
            steps {
                dir('CICD/mlflow') {
                    sh 'docker build -t mlflow-image .'
                }
            }
        }

        stage('Prepare Volume') {
            when {
                expression { currentBuild.result == null }
            }
            steps {
                sh 'mkdir -p tmp'
            }
        }

        stage('Start MLflow Server') {
            when {
                expression { currentBuild.result == null }
            }
            steps {
                script {
                    sh """
                    ENV_PATH=\$(pwd)/CICD/.env
                    if [ ! -f "\$ENV_PATH" ]; then
                        echo "Erreur : Le fichier .env est introuvable à \$ENV_PATH"
                        exit 1
                    fi

                    docker run -d --name mlflow-server \
                        --network mlflow-network \
                        --env-file "\$ENV_PATH" \
                        -v "\$(pwd)/tmp:/home/app/tmp" \
                        -p 4000:4000 \
                        mlflow-image
                    """
                }
            }
        }

        stage('Run Training Script') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        // Vérifiez la présence du fichier train.py
                        sh 'ls -la train.py'

                        // Confirmez la présence des fichiers montés dans le conteneur Docker
                        sh """
                        ENV_PATH=\$(pwd)/../CICD/.env
                        docker run --rm --network mlflow-network \
                            --env-file "\$ENV_PATH" \
                            -v "\$(pwd):/home/app" \
                            mlflow-image ls -la /home/app
                        """

                        // Exécutez le script d'entraînement
                        sh """
                        ENV_PATH=\$(pwd)/../CICD/.env
                        docker run --rm --network mlflow-network \
                            --env-file "\$ENV_PATH" \
                            -v "\$(pwd):/home/app" \
                            mlflow-image python /home/app/train.py
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Nettoyage des conteneurs et du réseau Docker...'
            sh """
            docker ps -q --filter network=mlflow-network | xargs -r docker network disconnect -f mlflow-network || true
            docker rm -f mlflow-server || true
            docker network rm mlflow-network || true
            rm -rf "\$(pwd)/tmp" || true
            """
        }
        success {
            echo 'Pipeline exécutée avec succès !'
        }
        failure {
            echo 'La pipeline a échoué.'
        }
    }
}
