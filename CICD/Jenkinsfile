pipeline {
    agent any
    environment {
        // Ajouter les credentials et variables d'environnement
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        BACKEND_STORE_URI = credentials('backend-store-uri')
        ARTIFACT_STORE_URI = credentials('artifact-store-uri')
    }
    stages {
        stage('Cloner le dépôt GitHub') {
            steps {
                // Cloner le dépôt depuis GitHub
                git branch: 'main', url: 'https://github.com/ManalKadiri/AIA-Project.git'
            }
        }
        stage('Entraîner le modèle avec MLflow') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        // Construire l'image Docker pour MLflow
                        sh 'docker build -t mlflow-training .'

                        // Lancer le conteneur pour entraîner le modèle
                        sh '''
                        docker run --rm \
                            -e AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID} \
                            -e AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY} \
                            -e BACKEND_STORE_URI=${BACKEND_STORE_URI} \
                            -e ARTIFACT_STORE_URI=${ARTIFACT_STORE_URI} \
                            mlflow-training python train.py
                        '''
                    }
                }
            }
        }
    }
    post {
        success {
            echo 'Pipeline exécuté avec succès !'
        }
        failure {
            echo 'Une erreur est survenue pendant le pipeline.'
        }
    }
}
