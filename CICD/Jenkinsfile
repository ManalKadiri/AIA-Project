pipeline {
    agent any
    environment {
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id') // Identifiants AWS sécurisés dans Jenkins
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    }
    stages {
        stage('Cloner le dépôt GitHub') {
            steps {
                git branch: 'main', url: 'https://github.com/ManalKadiri/AIA-Project.git'
            }
        }
        stage('Préparer les volumes') {
            steps {
                script {
                    sh '''
                    mkdir -p $(pwd)/artifacts
                    mkdir -p $(pwd)/mlruns
                    mkdir -p $(pwd)/datasets
                    touch $(pwd)/mlflow.db
                    '''
                }
            }
        }
        stage('Construire l’image Docker pour le serveur MLflow') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        sh 'docker build -t custom-mlflow-server -f Dockerfile .'
                    }
                }
            }
        }
        stage('Démarrer le serveur MLflow') {
            steps {
                script {
                    // Arrêter les conteneurs existants
                    sh 'docker rm -f mlflow-server || true'

                    // Lancer le serveur MLflow
                    sh '''
                    docker run -d --name mlflow-server \
                        -p 9000:4000 \
                        -v $(pwd)/artifacts:/home/app/artifacts \
                        -v $(pwd)/mlruns:/home/app/mlruns \
                        -v $(pwd)/mlflow.db:/home/app/mlflow.db \
                        custom-mlflow-server
                    '''
                }
            }
        }
        stage('Construire l’image Docker pour l’entraînement') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        sh 'docker build -t mlflow-training .'
                    }
                }
            }
        }
        stage('Entraîner le modèle avec MLflow') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        sh '''
                        docker run --rm \
                            -e AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID} \
                            -e AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY} \
                            -v $(pwd)/artifacts:/home/app/artifacts \
                            -v $(pwd)/datasets:/home/app/datasets \
                            mlflow-training python train.py
                        '''
                    }
                }
            }
        }
    }
    post {
        always {
            script {
                // Nettoyer les conteneurs restants
                sh 'docker rm -f mlflow-server || true'
            }
        }
        success {
            echo 'Pipeline exécuté avec succès !'
        }
        failure {
            echo 'Une erreur est survenue pendant l’exécution du pipeline.'
        }
    }
}
