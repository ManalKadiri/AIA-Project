pipeline {
    agent any
    environment {
        APP_URI = credentials('app-uri') // Nom du credential pour APP_URI
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id') // Credential AWS Access Key
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key') // Credential AWS Secret Key
        BACKEND_STORE_URI = credentials('backend-store-uri') // Credential Backend Store URI
        ARTIFACT_STORE_URI = credentials('artifact-store-uri') // Credential Artifact Store URI
        POSTMARK_API_KEY = credentials('postmark-api-key') // Credential Postmark API Key
        MLFLOW_EXPERIMENT_NAME = credentials('mlflow-experiment-name') // Credential pour le nom de l'expérience
    }
    stages {
        stage('Checkout') {
            steps {
                // Cloner le dépôt GitHub
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('CICD/mlflow') {
                    sh """
                    docker build -t mlflow-image --build-arg REPO_URL=https://github.com/username/project-name.git .
                    """
                }
            }
        }

        stage('Run Training Script') {
            steps {
                script {
                    sh """
                    docker run --env-file CICD/.env -p 4000:4000 mlflow-image python /home/app/CICD/mlflow/train.py
                    """
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    def test_result = sh(script: """
                    docker run --env-file CICD/.env \
                        mlflow-image \
                        pytest --maxfail=1 --disable-warnings -q /home/app/CICD/tests
                    """, returnStatus: true)

                    if (test_result != 0) {
                        echo "Tests failed. Sending alert email..."
                        sh """
                        docker run --env-file CICD/.env \
                            mlflow-image \
                            python /home/app/CICD/mlflow/send_email.py "Tests Failed" "Les tests ont échoué. Vérifiez les logs Jenkins."
                        """
                        error "Tests failed. Pipeline stopped."
                    } else {
                        echo "All tests passed successfully."
                    }
                }
            }
        }

        stage('Validate Model Performance') {
            steps {
                script {
                    def validation_passed = sh(script: """
                    docker run --env-file CICD/.env \
                        mlflow-image \
                        python /home/app/CICD/mlflow/check_model_performance.py
                    """, returnStatus: true)

                    if (validation_passed != 0) {
                        echo "Validation failed. Model does not meet performance criteria."
                        currentBuild.result = "UNSTABLE"
                    } else {
                        echo "Validation passed. Model meets performance criteria."
                    }
                }
            }
        }

        stage('Rollback to Previous Model (if needed)') {
            when {
                expression { currentBuild.result == "UNSTABLE" }
            }
            steps {
                sh """
                docker run --env-file CICD/.env \
                    mlflow-image \
                    python /home/app/CICD/mlflow/rollback_model.py
                """
            }
        }

        stage('Run API Container') {
            steps {
                sh """
                docker rm -f fraud-detection-api || true
                docker run -d -p 8005:8005 --name fraud-detection-api mlflow-image
                """
            }
        }
    }

    post {
        always {
            echo "Pipeline terminé. Vérifiez l'état des étapes."
        }
        failure {
            echo "Une erreur est survenue. Envoi d'un email d'alerte..."
            sh """
            docker run --env-file CICD/.env \
                mlflow-image \
                python /home/app/CICD/mlflow/send_email.py "Pipeline Jenkins Failed" "Une erreur est survenue. Vérifiez les logs Jenkins."
            """
        }
    }
}
