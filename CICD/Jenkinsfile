pipeline {
    agent any
    environment {
        APP_URI = credentials('app-uri') // Nom du credential pour APP_URI
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id') // Credential AWS Access Key
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key') // Credential AWS Secret Key
        BACKEND_STORE_URI = credentials('backend-store-uri') // Credential Backend Store URI
        ARTIFACT_STORE_URI = credentials('artifact-store-uri') // Credential Artifact Store URI
        POSTMARK_API_KEY = credentials('postmark-api-key') // Credential Postmark API Key
        MLFLOW_EXPERIMENT_NAME = credentials('mlflow-experiment-name') // Credential pour le nom de l'expérience
    }
    stages {
        stage('Checkout') {
            steps {
                // Cloner le code source depuis GitHub
                checkout scm
            }
        }

        stage('Build Docker Images') {
            steps {
                parallel (
                    "Build MLflow Image": {
                        dir('CICD/mlflow') {
                            sh 'docker build -t mlflow-image .'
                        }
                    },
                    "Build API Image": {
                        dir('CICD/API') {
                            sh 'docker build -t fraud-detection-api .'
                        }
                    }
                )
            }
        }

        stage('Generate .env File') {
            steps {
                dir('CICD') {
                    script {
                        writeFile file: '.env', text: """
APP_URI=${APP_URI}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
BACKEND_STORE_URI=${BACKEND_STORE_URI}
ARTIFACT_STORE_URI=${ARTIFACT_STORE_URI}
POSTMARK_API_KEY=${POSTMARK_API_KEY}
MLFLOW_EXPERIMENT_NAME=${MLFLOW_EXPERIMENT_NAME}
"""
                    }
                }
            }
        }

        stage('Run Training Script') {
            steps {
                dir('CICD/mlflow') {
                    sh """
                    docker run --env-file ../.env -p 4000:4000 -v "\$(pwd):/home/app" mlflow-image python /home/app/train.py
                    """
                }
            }
        }

        stage('Run Preprocessing Tests') {
            steps {
                dir('CICD') {
                    script {
                        def test_result = sh(script: """
                        docker run --env-file .env \
                            -v "\$(pwd)/tests:/home/app/tests" mlflow-image \
                            pytest --maxfail=1 --disable-warnings -q /home/app/tests/test_data_preprocessing.py
                        """, returnStatus: true)

                        if (test_result != 0) {
                            echo "Preprocessing tests failed. Sending alert email..."
                            sh """
                            python3 mlflow/send_email.py \
                                "Preprocessing Tests Failed" \
                                "Les tests de prétraitement ont échoué. Vérifiez les logs Jenkins."
                            """
                            error "Preprocessing tests failed. Pipeline stopped."
                        } else {
                            echo "Preprocessing tests passed successfully."
                        }
                    }
                }
            }
        }

        stage('Validate Model Performance') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        def validation_passed = sh(script: """
                        docker run --env-file ../.env \
                            -v "\$(pwd):/home/app" mlflow-image \
                            python /home/app/check_model_performance.py
                        """, returnStatus: true)

                        if (validation_passed != 0) {
                            echo "Validation failed. Model does not meet performance criteria."
                            currentBuild.result = "UNSTABLE"
                        } else {
                            echo "Validation passed. Model meets performance criteria."
                        }
                    }
                }
            }
        }

        stage('Rollback to Previous Model (if needed)') {
            when {
                expression { currentBuild.result == "UNSTABLE" }
            }
            steps {
                dir('CICD/mlflow') {
                    sh """
                    docker run --env-file ../.env \
                        -v "\$(pwd):/home/app" mlflow-image \
                        python /home/app/rollback_model.py
                    """
                }
            }
        }

        stage('Run API Container') {
            steps {
                script {
                    sh 'docker rm -f fraud-detection-api || true'
                    sh 'docker run -d -p 8005:8005 --name fraud-detection-api fraud-detection-api'
                }
            }
        }

        stage('Post-build Cleanup') {
            steps {
                echo "Cleaning up Docker containers and images..."
                sh '''
                docker ps -a --filter "ancestor=mlflow-image" -q | xargs -r docker rm -f
                docker ps -a --filter "ancestor=fraud-detection-api" -q | xargs -r docker rm -f
                docker rmi --force mlflow-image fraud-detection-api || true
                '''
            }
        }
    }

    post {
        always {
            echo "Pipeline terminé. Vérifiez l'état des étapes."
        }
        failure {
            echo "Une erreur est survenue. Envoi d'un email d'alerte..."
            dir('CICD/mlflow') {
                sh """
                python3 send_email.py \
                    "Pipeline Jenkins Échoué" \
                    "Le pipeline Jenkins a échoué dans une des étapes. Vérifiez les logs Jenkins."
                """
            }
        }
    }
}
