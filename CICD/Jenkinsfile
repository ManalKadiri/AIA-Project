pipeline {
    agent any
    environment {
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    }
    stages {
        stage('Cloner le dépôt GitHub') {
            steps {
                git branch: 'main', url: 'https://github.com/ManalKadiri/AIA-Project.git'
            }
        }
        stage('Préparer les volumes') {
            steps {
                script {
                    sh '''
                    mkdir -p $(pwd)/artifacts
                    mkdir -p $(pwd)/mlruns
                    mkdir -p $(pwd)/datasets
                    touch $(pwd)/mlflow.db
                    '''
                }
            }
        }
        stage('Construire l’image Docker générique') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        sh 'docker build -t mlflow-generic .'
                    }
                }
            }
        }
        stage('Démarrer le serveur MLflow') {
            steps {
                script {
                    // Arrêter les conteneurs existants
                    sh 'docker rm -f mlflow-server || true'

                    // Lancer le serveur MLflow sur le réseau personnalisé
                    sh '''
                    docker run -d --name mlflow-server --network mlflow-network \
                        -p 4000:4000 \
                        -v /var/jenkins_home/workspace/AIA-Project-Pipeline/CICD/mlflow/artifacts:/home/app/artifacts \
                        -v /var/jenkins_home/workspace/AIA-Project-Pipeline/CICD/mlflow/mlruns:/home/app/mlruns \
                        -v /var/jenkins_home/workspace/AIA-Project-Pipeline/CICD/mlflow/mlflow.db:/home/app/mlflow.db \
                        -e SERVICE=server \
                        mlflow-generic
                    '''
                }
            }
        }
        stage('Entraîner le modèle avec MLflow') {
            steps {
                dir('CICD/mlflow') {
                    script {
                        sh '''
                        docker run --rm --network mlflow-network \
                            -e AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID} \
                            -e AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY} \
                            -v $(pwd)/artifacts:/home/app/artifacts \
                            -v $(pwd)/datasets:/home/app/datasets \
                            mlflow-generic
                        '''
                    }
                }
            }
        }
    }
    post {
        always {
            script {
                // Nettoyer les conteneurs restants
                sh 'docker rm -f mlflow-server || true'
            }
        }
        success {
            echo 'Pipeline exécuté avec succès !'
        }
        failure {
            echo 'Une erreur est survenue pendant l’exécution du pipeline.'
        }
    }
}
